{
  "name": "climate-agentic-pipeline",
  "private": true,
  "version": "1.0.0",
  "description": "Agentic ESG evaluation pipeline for Aurora Energy — AA Impact Inc. Technical Evaluation",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "agent:run": "tsx src/agents/graph.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@langchain/anthropic": "^0.2.15",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^0.2.19",
    "@trpc/server": "^11.0.0-rc.446",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.4",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "drizzle-kit": "^0.22.8",
    "eslint": "^9.8.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
