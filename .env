# ============================================================
# Aurora Energy — ESG Agentic Pipeline
# AA Impact Inc. — Environment Configuration Template
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=database_url_here
DATABASE_SSL=require
PGSSLMODE=require

LLM_PROVIDER=anthropic

# ── Mock LLM Mode ────────────────────────────────────────────────
# Set to "true" to enable mock mode: returns hardcoded P-003 output without requiring
# an Anthropic API key. Useful for demonstrations and testing. All pipeline steps run
# end-to-end with deterministic output. Set to "false" or omit for production mode.
MOCK_LLM=false

ANTHROPIC_API_KEY=sk-ant-your_key_here
# ── LLM Model Selection
LLM_MODEL= model #claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ── tRPC Server ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Agent Configuration ───────────────────────────────────────
# Maximum execution time for a single pipeline run (ms)
AGENT_TIMEOUT_MS=120000

# Methodology version tag applied to all computed scores
METHODOLOGY_VERSION=v1.0.0

# ── Peer Benchmarks (override defaults if needed) ─────────────
# P-001: Scope 1 CO2 intensity peer average (tCO2 / $M revenue)
P001_PEER_BENCHMARK_INTENSITY=52.3

# P-002: TSX60 average board gender diversity (decimal)
P002_TSX60_AVERAGE_DIVERSITY=0.282

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
